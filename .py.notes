import json
import time

def log_mcp_transaction(ide_client_id: str, requested_tool: str, chroma_query: str, status_code: int):
    """
    Generates structured, immutable audit trails for enterprise security compliance.
    Ensures every semantic interaction from external IDEs (Cursor/Cline) is fully auditable.
    """
    audit_trail = {
        "timestamp": int(time.time()),
        "client_node": ide_client_id,
        "action": requested_tool,
        "payload_hash": hash(chroma_query),
        "status": status_code
    }
    print(json.dumps(audit_trail))
